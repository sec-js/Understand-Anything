---
const githubUrl = 'https://github.com/Egonex-AI/Understand-Anything';
const egonexUrl = 'https://egonex.ai';
---

<section class="hero" id="top">
  <div class="hero-bg">
    <img src="/images/hero.jpg" alt="" class="hero-bg-img" loading="eager" />
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content">
    <span class="hero-badge anim anim-1">AI-Powered Code Understanding</span>

    <h1 class="hero-title anim anim-2">
      <span class="hero-grad">Understand</span> Anything
    </h1>

    <p class="hero-bridge anim anim-3">
      <a href={egonexUrl} target="_blank" rel="noopener noreferrer">Understand Anyone.</a>
    </p>

    <p class="hero-belief anim anim-4">
      AI should help people, not replace them.
    </p>

    <p class="hero-tagline anim anim-4">
      Other tools show you a <span class="hero-problem">hairball</span>.
      We <span class="hero-value">teach</span> you the codebase.
    </p>

    <div class="hero-pillars anim anim-5">
      <span class="pillar">Structure & Dependencies</span>
      <span class="pillar-dot">&middot;</span>
      <span class="pillar">Business Logic</span>
      <span class="pillar-dot">&middot;</span>
      <span class="pillar">Guided Tours</span>
    </div>

    <div class="hero-actions anim anim-6">
      <a href="#install" class="hero-cta"><span>Get Started</span></a>
      <a href="#live-demo" class="hero-demo">Live Demo &rarr;</a>
      <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="hero-secondary">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" style="vertical-align:-2px;margin-right:4px;"><path d="M12 .587l3.668 7.568L24 9.306l-6 5.986 1.416 8.421L12 19.897l-7.416 3.816L6 15.292 0 9.306l8.332-1.151z"/></svg>
        Star on GitHub
      </a>
    </div>

    <a
      href="https://trendshift.io/repositories/23482"
      target="_blank"
      rel="noopener noreferrer"
      class="hero-trendshift anim anim-6"
    >
      <span class="trend-fallback" aria-hidden="true">
        <span class="trend-rank">
          <svg class="trend-laurel trend-laurel-left" viewBox="0 0 22 32" focusable="false">
            <path d="M17 5C10 10 6 17 7 26" />
            <path d="M12 9C8 9 6 11 5 14" />
            <path d="M9 15C5 16 4 18 4 21" />
            <path d="M9 22C6 23 5 25 6 28" />
          </svg>
          <span class="trend-number">1</span>
          <svg class="trend-laurel" viewBox="0 0 22 32" focusable="false">
            <path d="M5 5c7 5 11 12 10 21" />
            <path d="M10 9c4 0 6 2 7 5" />
            <path d="M13 15c4 1 5 3 5 6" />
            <path d="M13 22c3 1 4 3 3 6" />
          </svg>
        </span>
        <span class="trend-copy">
          <span class="trend-kicker">GitHub Trending</span>
          <span class="trend-title">#1 Repository Of The Day</span>
        </span>
      </span>
      <img
        src="https://trendshift.io/api/badge/repositories/23482"
        alt="Understand Anything | Trendshift"
        width="250"
        height="55"
        loading="lazy"
        onerror="this.style.display='none'"
      />
    </a>

  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    padding: 7rem 2rem 5rem;
    background: transparent;
    color: var(--text);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(circle at 12% 12%, rgba(147, 197, 253, 0.22), transparent 34rem),
      radial-gradient(circle at 82% 22%, rgba(139, 92, 246, 0.24), transparent 34rem),
      linear-gradient(180deg, #fbfdff 0%, #f8f8fd 100%);
    -webkit-mask-image: linear-gradient(180deg, #000 0%, #000 72%, rgba(0, 0, 0, 0.72) 84%, transparent 100%);
    mask-image: linear-gradient(180deg, #000 0%, #000 72%, rgba(0, 0, 0, 0.72) 84%, transparent 100%);
  }

  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url('/images/hero.jpg');
    background-size: cover;
    background-position: center;
    opacity: 0.14;
    filter: saturate(0.72) contrast(1.18) brightness(1.04) sepia(0.08) hue-rotate(218deg);
    mix-blend-mode: multiply;
    -webkit-mask-image:
      radial-gradient(ellipse at 17% 48%, #000 0%, #000 24%, transparent 50%),
      radial-gradient(ellipse at 84% 48%, #000 0%, #000 24%, transparent 50%);
    mask-image:
      radial-gradient(ellipse at 17% 48%, #000 0%, #000 24%, transparent 50%),
      radial-gradient(ellipse at 84% 48%, #000 0%, #000 24%, transparent 50%);
  }

  .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.08;
    filter: saturate(0.7) contrast(1.06) brightness(1.08);
    mix-blend-mode: multiply;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 50% 42%, rgba(255, 255, 255, 0.98) 0%, rgba(255, 255, 255, 0.9) 24%, rgba(255, 255, 255, 0.56) 48%, transparent 70%),
      linear-gradient(180deg, rgba(251, 253, 255, 0.82) 0%, rgba(248, 248, 253, 0.4) 36%, rgba(248, 248, 253, 0.76) 74%, var(--bg) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    width: min(100%, 1180px);
    max-width: 1180px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  /* Badge */
  .hero-badge {
    display: inline-block;
    font-family: var(--font-code);
    font-size: 0.78rem;
    letter-spacing: 0.02em;
    color: var(--accent-deep);
    border: 1px solid rgba(88, 43, 232, 0.18);
    background: rgba(255, 255, 255, 0.72);
    box-shadow: var(--shadow-card);
    backdrop-filter: blur(18px) saturate(1.12);
    padding: 0.45rem 1.15rem;
    border-radius: 100px;
    margin-bottom: 2rem;
  }

  /* Headline */
  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(3.25rem, 7.2vw, 6rem);
    color: var(--text);
    font-weight: 850;
    line-height: 0.95;
    letter-spacing: -0.06em;
    margin-bottom: 1.55rem;
    white-space: nowrap;
    max-width: 100%;
    text-shadow: none;
  }

  .hero-grad {
    display: inline-block;
    background: linear-gradient(135deg, #0f1020, #4c35d9 58%, #8b5cf6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-shadow: none;
  }

  .hero-bridge {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: var(--text);
    font-family: var(--font-heading);
    font-weight: 760;
    font-size: 1.8rem;
    line-height: 1.25;
    margin: -0.4rem 0 0.8rem;
  }

  .hero-bridge a {
    color: var(--accent);
    text-decoration: none;
    transition: color 0.2s ease, text-shadow 0.2s ease;
  }

  .hero-bridge a:hover {
    color: var(--accent-deep);
    text-decoration: none;
    text-shadow: 0 0 20px rgba(88, 43, 232, 0.14);
  }

  .hero-belief {
    color: var(--text-muted);
    font-size: 1.08rem;
    line-height: 1.6;
    margin: 0 0 0.75rem;
  }

  /* Tagline */
  .hero-tagline {
    font-size: 1.08rem;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 900px;
    white-space: nowrap;
    margin-bottom: 1.5rem;
  }

  .hero-problem {
    color: #8b5cf6;
    font-style: italic;
  }

  .hero-value {
    color: var(--accent);
    font-weight: 600;
  }

  /* Pillars */
  .hero-pillars {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .pillar {
    font-size: 0.9rem;
    color: var(--text-soft);
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  .pillar-dot {
    color: var(--accent);
    font-size: 1.2rem;
    line-height: 1;
  }

  /* CTAs */
  .hero-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .hero-cta {
    background: var(--egonex-gradient-primary);
    color: #ffffff;
    padding: 1px;
    border-radius: 999px;
    font-weight: 600;
    font-size: 1.05rem;
    text-decoration: none;
    box-shadow: none;
    transition: transform 0.2s ease;
  }

  .hero-cta span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 2.5rem;
    border-radius: 999px;
    background: #582be8;
    transition: background 0.3s ease;
  }

  .hero-cta:hover {
    text-decoration: none;
  }

  .hero-cta:hover span,
  .hero-cta:focus-visible span {
    background: transparent;
  }

  .hero-demo {
    border: 1.5px solid rgba(88, 43, 232, 0.24);
    color: var(--accent);
    background: rgba(255, 255, 255, 0.68);
    padding: 0.85rem 2.5rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: 1.05rem;
    text-decoration: none;
    transition: background 0.3s ease, box-shadow 0.3s ease, transform 0.2s ease;
  }

  .hero-demo:hover {
    background: #ffffff;
    box-shadow: 0 12px 28px rgba(88, 43, 232, 0.18);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .hero-cta:active,
  .hero-demo:active {
    transform: scale(0.98);
  }

  .hero-secondary {
    color: var(--text-muted);
    font-size: 0.95rem;
    text-decoration: none;
    transition: color 0.2s;
  }

  .hero-secondary:hover {
    color: var(--accent);
    text-decoration: none;
  }

  /* Trendshift badge */
  .hero-trendshift {
    margin-top: 1.75rem;
    display: inline-block;
    position: relative;
    width: 250px;
    height: 55px;
    line-height: 1;
    transition: transform 0.2s ease, filter 0.2s ease;
  }

  .hero-trendshift img {
    display: block;
    position: absolute;
    inset: 0;
    z-index: 2;
    width: 250px;
    height: 55px;
  }

  .hero-trendshift:hover {
    transform: translateY(-2px);
    filter: drop-shadow(0 12px 20px rgba(88, 43, 232, 0.14));
  }

  .trend-fallback {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.52rem;
    padding: 0.42rem 0.62rem;
    border: 1.5px solid var(--accent);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 14px 32px rgba(88, 43, 232, 0.12);
    color: #4b2a92;
  }

  .trend-rank {
    display: inline-flex;
    align-items: center;
    gap: 0.12rem;
    flex: 0 0 auto;
    color: var(--accent);
  }

  .trend-number {
    font-family: var(--font-heading);
    font-size: 1.22rem;
    font-weight: 780;
    letter-spacing: 0;
  }

  .trend-laurel {
    width: 14px;
    height: 23px;
    overflow: visible;
  }

  .trend-laurel path {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.7;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .trend-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.17rem;
    min-width: 0;
  }

  .trend-kicker {
    font-family: var(--font-heading);
    color: #6d58b5;
    font-size: 0.5rem;
    font-weight: 760;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .trend-title {
    font-family: var(--font-heading);
    color: #4b2a92;
    font-size: 0.76rem;
    font-weight: 780;
    letter-spacing: 0;
    white-space: nowrap;
  }

  /* Staggered entrance */
  @keyframes heroIn {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .anim {
    opacity: 0;
    animation: heroIn 0.8s ease-out forwards;
  }

  .anim-1 { animation-delay: 0.1s; }
  .anim-2 { animation-delay: 0.3s; }
  .anim-3 { animation-delay: 0.55s; }
  .anim-4 { animation-delay: 0.75s; }
  .anim-5 { animation-delay: 0.95s; }
  .anim-6 { animation-delay: 1.1s; }

  /* Responsive */
  @media (max-width: 900px) {
    .hero-bridge {
      max-width: 26ch;
    }
    .hero-belief {
      max-width: 34ch;
    }
    .hero-tagline {
      white-space: normal;
      max-width: 36ch;
      margin-left: auto;
      margin-right: auto;
    }
  }

  @media (max-width: 768px) {
    .hero { padding: 5rem 1.5rem 3rem; min-height: auto; }
    .hero-content { gap: 0; }
    .hero-pillars { gap: 0.5rem; margin-bottom: 2.25rem; }
    .pillar { font-size: 0.8rem; }
    .hero-badge {
      font-size: 0.72rem;
      padding: 0.35rem 1rem;
      margin-bottom: 1.75rem;
    }
    .hero-title { margin-bottom: 1.5rem; }
    .hero-bridge {
      font-size: 1.35rem;
      margin-top: -0.25rem;
    }
    .hero-belief,
    .hero-tagline {
      font-size: 0.98rem;
    }
  }

  @media (max-width: 640px) {
    .hero-title {
      white-space: normal;
      line-height: 1.02;
      letter-spacing: -0.03em;
      text-wrap: balance;
    }
    /* Stack the two words on dedicated lines for editorial drama */
    .hero-title .hero-grad { display: block; }
  }

  @media (max-width: 540px) {
    .hero-actions {
      flex-direction: column;
      gap: 0.75rem;
      width: 100%;
      max-width: 320px;
    }
    .hero-cta,
    .hero-demo {
      width: 100%;
      text-align: center;
      padding: 0.85rem 1.5rem;
      justify-content: center;
    }

    .hero-cta span {
      width: 100%;
      padding: 0.85rem 1.5rem;
    }
    .hero-pillars { flex-direction: column; gap: 0.4rem; }
    .pillar-dot { display: none; }
  }

  @media (max-width: 480px) {
    .hero { padding: 4rem 1.25rem 2.25rem; }
  }
</style>
